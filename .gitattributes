# Force LF line endings for ALL files on checkout (Windows-safe)
* text=auto eol=lf

# Explicitly force critical files to LF
*.js        text eol=lf
*.json      text eol=lf
*.ts        text eol=lf
*.kt        text eol=lf
*.java      text eol=lf
*.xml       text eol=lf
*.gradle    text eol=lf
*.properties text eol=lf
*.md        text eol=lf
*.pro       text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.sh        text eol=lf
gradlew     text eol=lf

# Binary files - never touch
*.apk    binary
*.jar    binary
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.keystore binary
*.bat    text eol=crlf
